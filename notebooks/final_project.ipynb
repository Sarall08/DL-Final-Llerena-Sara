        "if TASK == 'classification':\n",
        "    if OUTPUT_SIZE == 2:\n",
        "        model_keras.compile(\n",
        "            optimizer=keras.optimizers.Adam(learning_rate=LEARNING_RATE),\n",
        "            loss='binary_crossentropy',\n",
        "            metrics=['accuracy']\n",
